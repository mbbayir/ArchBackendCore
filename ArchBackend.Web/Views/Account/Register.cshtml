
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Register</title>
</head>
<body>
	@model ArchBackend.Core.ViewModels.RegisterViewModel

    <h2>Register</h2>
    <form asp-action="Register" method="post">
        <input asp-for="FirstName" placeholder="First Name" />
        <input asp-for="LastName" placeholder="Last Name" />
        <input asp-for="UserName" placeholder="Username" />
        <input asp-for="Email" placeholder="Email" />
        <input asp-for="Password" type="password" placeholder="Password" />
        <input asp-for="ConfirmPassword" type="password" placeholder="Confirm Password" />
        <button type="submit">Register</button>
    </form>

</body>
</html>
